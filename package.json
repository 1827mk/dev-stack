{
  "name": "@dev-stack/plugin",
  "version": "6.0.0",
  "description": "Meta-Orchestrator plugin for Claude Code - Natural language task execution with automatic tool selection",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint lib --ext .ts",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "orchestrator",
    "meta-orchestrator",
    "natural-language",
    "thai",
    "context-aware",
    "thinking",
    "research",
    "agents"
  ],
  "author": {
    "name": "dev-stack",
    "url": "https://github.com/dev-stack"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "js-yaml": "^4.1.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  },
  "files": [
    "dist",
    ".claude-plugin",
    ".dev-stack"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-stack/plugin.git"
  },
  "bugs": {
    "url": "https://github.com/dev-stack/plugin/issues"
  },
  "homepage": "https://github.com/dev-stack/plugin#readme"
}
